{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "еПЃеТЪеЕДеЉЯ",
  "version": "0.7.0",
  "identifier": "com.dingdongbro.game",
  "build": {
    "frontendDist": "../build/desktop-shell",
    "beforeDevCommand": "bun scripts/build-desktop-shell.ts",
    "beforeBuildCommand": "bun scripts/build-desktop-shell.ts"
  },
  "app": {
    "windows": [
      {
        "title": "еПЃеТЪеЕДеЉЯ",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
